<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_repair_order_form_inherit" model="ir.ui.view">
        <field name="name">repair.order.form.inherit.mrp</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">
            
            <!-- Smart button para navegar para ordem de produção -->
            <xpath expr="//button[@name='action_view_sale_order']" position="before">
                <field name="mrp_production_id" invisible="1"/>
                <button 
                    class="oe_stat_button"
                    name="action_view_repair_manufacturing_order"
                    type="object"
                    icon="fa-industry"
                    invisible="not mrp_production_id"
                >
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Manufacturing Order</span>
                    </div>
                </button>
            </xpath>
            
        </field>
    </record>
</odoo>
